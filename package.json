{
  "name": "zigmastorage",
  "author": "CMOISDEAD",
  "description": "a very simple localStorage handler",
  "version": "0.0.3",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/zigmastorage.umd.js",
  "module": "./dist/zigmastorage.es.js",
  "types": "./dist/lib/main.d.ts",
  "scripts": {
